{
  "spec": "akep.v1",
  "sink": "agent.local.property-buyer",
  "event_types": ["knowledge.acquired", "tool.failed", "human.review_required"],
  "filters": {
    "source.name": "sense2ai",
    "subject.agent_id": "agent_buyer_991"
  },
  "delivery": {
    "type": "long_poll",
    "url": "https://relay.akep.dev/akep/events/wait",
    "ack_required": true,
    "replay_retention_seconds": 604800
  },
  "security": {
    "accepted_source_names": ["sense2ai"],
    "accepted_producer_ids": ["prod_sense2ai_01"],
    "signature_key_ids": ["2026-05"]
  },
  "capabilities": {
    "resume_policies": ["append_only", "resume_if_waiting"],
    "max_payload_bytes": 1048576
  }
}
